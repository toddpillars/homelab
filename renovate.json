{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "kubernetes": {
    "fileMatch": ["\\.yaml$", "\\.yml$"]
  },
  "flux": {
    "fileMatch": [
      "(^|/)infrastructure/.+\\.ya?ml$",
      "(^|/)clusters/.+\\.ya?ml$"
    ]
  },
  "helm-values": {
    "fileMatch": [
      "(^|/).*values\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "description": "Auto-merge Helm chart updates",
      "matchDatasources": ["helm"],
      "automerge": false,
      "automergeType": "pr"
    },
    {
      "description": "Group all Postiz-stack image updates into a single PR",
      "matchFileNames": ["infrastructure/controllers/base/postiz/**"],
      "groupName": "postiz-stack"
    }
  ]
}
